all: all-am

.SUFFIXES:
.SUFFIXES: .cc .o .obj
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --gnu  src/Makefile'; \
	cd $(top_srcdir) && \
	  $(AUTOMAKE) --gnu  src/Makefile
.PRECIOUS: Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
install-binPROGRAMS: $(bin_PROGRAMS)
	@$(NORMAL_INSTALL)
	test -z "$(bindir)" || $(mkdir_p) "$(DESTDIR)$(bindir)"
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  p1=`echo $$p|sed 's/$(EXEEXT)$$//'`; \
	  if test -f $$p \
	  ; then \
	    f=`echo "$$p1" | sed 's,^.*/,,;$(transform);s/$$/$(EXEEXT)/'`; \
	   echo " $(INSTALL_PROGRAM_ENV) $(binPROGRAMS_INSTALL) '$$p' '$(DESTDIR)$(bindir)/$$f'"; \
	   $(INSTALL_PROGRAM_ENV) $(binPROGRAMS_INSTALL) "$$p" "$(DESTDIR)$(bindir)/$$f" || exit 1; \
	  else :; fi; \
	done

uninstall-binPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  f=`echo "$$p" | sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  echo " rm -f '$(DESTDIR)$(bindir)/$$f'"; \
	  rm -f "$(DESTDIR)$(bindir)/$$f"; \
	done

clean-binPROGRAMS:
	-test -z "$(bin_PROGRAMS)" || rm -f $(bin_PROGRAMS)

clean-noinstPROGRAMS:
	-test -z "$(noinst_PROGRAMS)" || rm -f $(noinst_PROGRAMS)
cthugha$(EXEEXT): $(cthugha_OBJECTS) $(cthugha_DEPENDENCIES) 
	@rm -f cthugha$(EXEEXT)
	$(CXXLINK) $(cthugha_LDFLAGS) $(cthugha_OBJECTS) $(cthugha_LDADD) $(LIBS)
cthugha-server$(EXEEXT): $(cthugha_server_OBJECTS) $(cthugha_server_DEPENDENCIES) 
	@rm -f cthugha-server$(EXEEXT)
	$(CXXLINK) $(cthugha_server_LDFLAGS) $(cthugha_server_OBJECTS) $(cthugha_server_LDADD) $(LIBS)
glcthugha$(EXEEXT): $(glcthugha_OBJECTS) $(glcthugha_DEPENDENCIES) 
	@rm -f glcthugha$(EXEEXT)
	$(CXXLINK) $(glcthugha_LDFLAGS) $(glcthugha_OBJECTS) $(glcthugha_LDADD) $(LIBS)
tabheader$(EXEEXT): $(tabheader_OBJECTS) $(tabheader_DEPENDENCIES) 
	@rm -f tabheader$(EXEEXT)
	$(CXXLINK) $(tabheader_LDFLAGS) $(tabheader_OBJECTS) $(tabheader_LDADD) $(LIBS)
tabinfo$(EXEEXT): $(tabinfo_OBJECTS) $(tabinfo_DEPENDENCIES) 
	@rm -f tabinfo$(EXEEXT)
	$(CXXLINK) $(tabinfo_LDFLAGS) $(tabinfo_OBJECTS) $(tabinfo_LDADD) $(LIBS)
xcthugha$(EXEEXT): $(xcthugha_OBJECTS) $(xcthugha_DEPENDENCIES) 
	@rm -f xcthugha$(EXEEXT)
	$(CXXLINK) $(xcthugha_LDFLAGS) $(xcthugha_OBJECTS) $(xcthugha_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

